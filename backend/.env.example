# Скопируй в backend/.env и поправь под себя.

# Подключение к PostgreSQL (для docker-compose хост = db)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/coolcatkit

# Секрет для подписи JWT — на проде задать СВОЙ длинный случайный
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# Откуда фронту разрешено стучаться (через запятую). На проде — адрес GitHub Pages:
# CORS_ORIGINS=https://ТВОЙ-логин.github.io
CORS_ORIGINS=*

# Папка для загруженных картинок
MEDIA_DIR=./media

# Автосоздание таблиц + сид пород при старте (1/0)
AUTO_INIT_DB=1
